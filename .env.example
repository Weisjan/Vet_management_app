APP_NAME=Vet Reputation AI
APP_ENV=local
DEBUG=true
API_V1_PREFIX=/api/v1
SECRET_KEY=change-me-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=60

POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=vet_reputation
POSTGRES_USER=vet_reputation
POSTGRES_PASSWORD=vet_reputation
DATABASE_URL=postgresql+psycopg://vet_reputation:vet_reputation@postgres:5432/vet_reputation

REDIS_URL=redis://redis:6379/0
RQ_QUEUES=default,ai,notifications,review_requests

AI_PROVIDER=mock
EMAIL_PROVIDER=mock
DEFAULT_FROM_EMAIL=no-reply@example.local

LOG_LEVEL=INFO
